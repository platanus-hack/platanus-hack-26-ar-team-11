# =============================================================================
# .env.example — copiá a .env.local y completá con tus credenciales.
# =============================================================================
# Ver DEFINITIONS.md ítem 17 para qué env consume cada componente.
# =============================================================================


# Supabase (https://supabase.com — proyecto cloud free tier)
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Aliases server-side (algunos paths del worker leen sin NEXT_PUBLIC_).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Anthropic — LLM (el "cerebro" del bot). Requiere saldo (~$5–10 USD).
# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Deepgram — Speech-to-text. $200 USD gratis al registrarse.
# https://console.deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs — Text-to-speech. 10k créditos/mes free; Starter $5 para library voices vía API.
# https://elevenlabs.io
ELEVENLABS_API_KEY=
# Voice ID. Default Malena (argentina): p7AwDmKvTdoHTBuueGvP
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_NAME=Malena

# LiveKit Cloud — WebRTC. 5k min/mes free.
# https://cloud.livekit.io
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Beyond Presence — avatar fotorealista. Free tier con trial credits.
# https://app.bey.dev/
BEY_API_KEY=
NEXT_PUBLIC_BEY_AVATAR_ID=

# Ready Player Me — fallback 3D avatar (TalkingHead).
# Acordate del query string ?morphTargets=ARKit,Oculus%20Visemes
NEXT_PUBLIC_AVATAR_GLB_URL=

# Worker toggles
STT_PROVIDER=deepgram
NEXT_PUBLIC_NONVERBAL_DEBUG=1

# Twin Protocol ↔ AllAccess — secretos compartidos para /connect.
# Inventados para el MVP. Default dev abajo; cambiar antes de prod.
TWIN_PROTOCOL_BASE_URL=http://localhost:3000
TWIN_PROTOCOL_API_URL=http://localhost:3000
TWIN_PROTOCOL_CLIENT_ID=allaccess_demo
TWIN_PROTOCOL_CLIENT_SECRET=
ALLACCESS_CLIENT_SECRET=
ALLACCESS_PROD_URL=http://localhost:5173
DEMO_USER_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
