{
  "name": "twin-protocol",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:seed": "tsx --env-file=.env.local src/lib/db/seed.ts",
    "worker": "tsx --env-file=.env.local worker/index.ts dev",
    "worker:start": "tsx --env-file=.env.local worker/index.ts start",
    "worker:download": "tsx --env-file=.env.local worker/index.ts download-files"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@hookform/resolvers": "^5.2.2",
    "@livekit/agents": "1.3.2",
    "@livekit/agents-plugin-deepgram": "1.3.2",
    "@livekit/agents-plugin-elevenlabs": "1.3.2",
    "@livekit/agents-plugin-livekit": "1.3.2",
    "@livekit/agents-plugin-silero": "1.3.2",
    "@livekit/rtc-node": "^0.13.27",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "livekit-server-sdk": "^2.15.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
